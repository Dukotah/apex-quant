# Apex Quant — environment variables
# Copy to .env (gitignored). NEVER commit real keys.

# ---- THE SWITCH ----
# backtest = historical replay, no broker
# paper    = live data + simulated fills (no real money) ← default
# live     = real broker, REAL MONEY (only after 30+ days proven paper)
APEX_MODE=paper
APEX_BROKER=alpaca

# ---- Capital ----
APEX_CAPITAL=100000

# ---- Alpaca credentials ----
# Get free paper keys at alpaca.markets → dashboard → API keys.
# Paper keys are safe (no real money). Add LIVE keys only when going live.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ---- Optional: free push notifications (ntfy.sh, no account needed) ----
# Pick any unguessable topic name; subscribe in the ntfy app.
NTFY_TOPIC=

# ---- Optional: external dead-man's-switch (NEXT-7) ----
# An OFF-GitHub liveness monitor (e.g. free healthchecks.io). run_once pings this
# URL on every successful cycle and <url>/fail on an errored one. If the pings stop
# — because a run errored, preflight skipped the cycle, or the GitHub schedule never
# fired — the monitor emails you. This catches the exact blind spot the in-repo
# watchdog.yml cannot (it runs on the same scheduler it polices). Unset = disabled.
# Create a free check at https://healthchecks.io and paste its ping URL here.
APEX_HEARTBEAT_URL=
